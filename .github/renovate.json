{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "dependencyDashboard": true,
  "extends": [
    "config:best-practices"
  ],
  "rangeStrategy": "pin",
  "prCreation": "immediate",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "semanticCommits": "enabled",
  "timezone": "Asia/Shanghai",
  "schedule": [
    "at any time"
  ],
  "automergeSchedule": [
    "at any time"
  ],
  "enabledManagers": [
    "js",
    "github-actions"
  ],
  "managerFilePatterns": [
    "/(?:^|\/).github\/package.json$/"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "*"
      ],
      "automerge": true,
      "automergeType": "branch",
      "automergeStrategy": "rebase",
      "ignoreTests": true
    }
  ]
}